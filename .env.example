# Copia este archivo a .env o define las variables en tu sistema / Vercel.
# Nunca subas .env con secretos reales al repositorio.

# Clave del panel admin (mínimo 16 caracteres).
# Debe ser la MISMA que introduces en admin.html al iniciar sesión.
# En Windows (PowerShell): $env:ADMIN_SECRET="tu_clave_larga_aqui"
# En Vercel: Project → Settings → Environment Variables → ADMIN_SECRET
ADMIN_SECRET=cambia_esto_por_una_clave_larga_de_al_menos_16_caracteres
 