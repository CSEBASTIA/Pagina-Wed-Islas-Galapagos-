{
    "rewrites": [
        {
            "source": "/api/auth/google",
            "destination": "/api/auth/google"
        },
        {
            "source": "/api/auth/callback",
            "destination": "/api/auth/callback"
        },
        {
            "source": "/api/admin/ping",
            "destination": "/api/admin/ping"
        },
        {
            "source": "/api/tours/reset",
            "destination": "/api/tours/reset"
        },
        {
            "source": "/api/tours/:id",
            "destination": "/api/tours/[id]"
        },
        {
            "source": "/api/tours",
            "destination": "/api/tours/index"
        },
        {
            "source": "/api/reviews",
            "destination": "/api/reviews/index"
        },
        {
            "source": "/api/gallery/:island/upload",
            "destination": "/api/gallery/upload?island=:island"
        },
        {
            "source": "/api/gallery/:island/:file",
            "destination": "/api/gallery/delete?island=:island&file=:file"
        },
        {
            "source": "/api/gallery/:island",
            "destination": "/api/gallery/list?island=:island"
        },
        {
            "source": "/api/activities/:id",
            "destination": "/api/activities/[id]"
        },
        {
            "source": "/api/activities",
            "destination": "/api/activities/index"
        }
    ]
}